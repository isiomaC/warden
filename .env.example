# Warden Environment Variables
# ----------------------------
# These are optional overrides for the Docker container.
# Default values work for most local development setups.
#
# All configuration-driven behavior should go through warden.config.yml.
# Use env vars only for operational concerns (ports, paths, tokens).

# Hook server configuration
# WARDEN_PORT=7429
# WARDEN_CONFIG_PATH=/app/warden.config.yml
# WARDEN_DB_PATH=/app/.warden/ledger.db

# Node environment
# NODE_ENV=development

# Approval channel (if using Telegram bot)
# TELEGRAM_BOT_TOKEN=

# Log level — controls structured JSON log verbosity.
# Values: debug (0), info (1), warn (2), error (3).
# debug: all messages including debug details.
# info:  informational messages and above (default).
# warn:  warning and error messages only.
# error: errors only.
LOG_LEVEL=info
